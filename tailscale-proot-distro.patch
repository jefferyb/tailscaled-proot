+// netInterfacesFallback parses ifconfig output to get interface info
+// when net.Interfaces() fails (e.g., on Android/PRoot where netlink is blocked).
+func netInterfacesFallback() ([]Interface, error) {
+	cmd := exec.Command("ifconfig")
+	out, err := cmd.Output()
+	if err != nil {
+		return []Interface{}, nil
+	}
+	return parseIfconfigOutput(string(out))
+}
+
+func parseIfconfigOutput(output string) ([]Interface, error) {
+	var ret []Interface
+	blocks := strings.Split(output, "\n\n")
+	idx := 1
+	for _, block := range blocks {
+		block = strings.TrimSpace(block)
+		if block == "" {
+			continue
+		}
+		lines := strings.Split(block, "\n")
+		firstLine := lines[0]
+
+		colonIdx := strings.Index(firstLine, ":")
+		if colonIdx == -1 {
+			continue
+		}
+		name := strings.TrimSpace(firstLine[:colonIdx])
+
+		var flags net.Flags
+		mtu := 0
+
+		if flagStart := strings.Index(firstLine, "flags="); flagStart != -1 {
+			rest := firstLine[flagStart+6:]
+			if ltIdx := strings.Index(rest, "<"); ltIdx != -1 {
+				if gtIdx := strings.Index(rest, ">"); gtIdx != -1 {
+					flagStr := rest[ltIdx+1 : gtIdx]
+					for _, f := range strings.Split(flagStr, ",") {
+						switch f {
+						case "UP":
+							flags |= net.FlagUp
+						case "BROADCAST":
+							flags |= net.FlagBroadcast
+						case "LOOPBACK":
+							flags |= net.FlagLoopback
+						case "POINTOPOINT":
+							flags |= net.FlagPointToPoint
+						case "MULTICAST":
+							flags |= net.FlagMulticast
+						case "RUNNING":
+							flags |= net.FlagRunning
+						}
+					}
+				}
+			}
+			if mtuIdx := strings.Index(firstLine, "mtu "); mtuIdx != -1 {
+				fmt.Sscanf(firstLine[mtuIdx+4:], "%d", &mtu)
+			}
+		}
+
+		iface := &net.Interface{
+			Index: idx,
+			MTU:   mtu,
+			Name:  name,
+			Flags: flags,
+		}
+		idx++
+
+		var altAddrs []net.Addr
+		for _, line := range lines[1:] {
+			line = strings.TrimSpace(line)
+			if strings.HasPrefix(line, "inet ") {
+				fields := strings.Fields(line)
+				if len(fields) >= 2 {
+					ipStr := fields[1]
+					maskStr := ""
+					for i, f := range fields {
+						if f == "netmask" && i+1 < len(fields) {
+							maskStr = fields[i+1]
+						}
+					}
+					ip := net.ParseIP(ipStr)
+					if ip != nil {
+						mask := net.CIDRMask(32, 32)
+						if maskStr != "" {
+							if parsedMask := net.ParseIP(maskStr); parsedMask != nil {
+								mask = net.IPMask(parsedMask.To4())
+							}
+						}
+						altAddrs = append(altAddrs, &net.IPNet{IP: ip, Mask: mask})
+					}
+				}
+			} else if strings.HasPrefix(line, "inet6 ") {
+				fields := strings.Fields(line)
+				if len(fields) >= 2 {
+					cidr := fields[1]
+					if strings.Contains(cidr, "/") {
+						_, ipNet, err := net.ParseCIDR(cidr)
+						if err == nil {
+							ip := net.ParseIP(strings.Split(cidr, "/")[0])
+							if ip != nil {
+								ipNet.IP = ip
+							}
+							altAddrs = append(altAddrs, ipNet)
+						}
+					} else {
+						prefixLen := 0
+						for i, f := range fields {
+							if f == "prefixlen" && i+1 < len(fields) {
+								fmt.Sscanf(fields[i+1], "%d", &prefixLen)
+							}
+						}
+						ip := net.ParseIP(cidr)
+						if ip != nil {
+							if prefixLen == 0 {
+								prefixLen = 128
+							}
+							altAddrs = append(altAddrs, &net.IPNet{IP: ip, Mask: net.CIDRMask(prefixLen, 128)})
+						}
+					}
+				}
+			}
+		}
+
+		ni := Interface{Interface: iface}
+		if len(altAddrs) > 0 {
+			ni.AltAddrs = altAddrs
+		} else {
+			ni.AltAddrs = []net.Addr{}
+		}
+		ret = append(ret, ni)
+	}
+	return ret, nil
+}
