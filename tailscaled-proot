#!/bin/bash
# tailscaled-proot - Install and manage a patched Tailscale daemon for PRoot-Distro (Termux)
#
# Provides patched tailscale and tailscaled binaries that work in PRoot-Distro
# on Android without root. Includes SSH server and Taildrop support.
#
# Usage:
#   tailscaled-proot install     Install tailscale + tailscaled and set up auto-start
#   tailscaled-proot update      Update to the latest version
#   tailscaled-proot status      Show current versions and daemon status
#   tailscaled-proot uninstall   Remove tailscale, tailscaled, and auto-start
#   tailscaled-proot help        Show this help message
#
# This project is not affiliated with or endorsed by Tailscale Inc.
# "Tailscale" is a registered trademark of Tailscale Inc.
# Tailscale source code is licensed under BSD-3-Clause.
#
# Repository: https://github.com/jefferyb/tailscaled-proot

set -euo pipefail

GITHUB_REPO="jefferyb/tailscaled-proot"
SCRIPT_VERSION="1.1.0"
SCRIPT_URL="https://raw.githubusercontent.com/$GITHUB_REPO/main/tailscaled-proot"
CLI_DIR="/usr/bin"
DAEMON_DIR="/usr/sbin"
SCRIPT_DIR="/usr/local/bin"
STATE_DIR="/var/lib/tailscale"
SOCKET_DIR="/var/run/tailscale"
SOCKET="$SOCKET_DIR/tailscaled.sock"
BASHRC="${HOME}/.bashrc"
BASHRC_MARKER="# --- tailscaled-proot auto-start ---"
BASHRC_END_MARKER="# --- end tailscaled-proot ---"
LEGACY_BASHRC_MARKER="# Auto-start tailscaled if not already running"

# Temp directory for downloads (cleaned up on exit)
_TMPDIR=""
_cleanup() { [ -n "$_TMPDIR" ] && rm -rf "$_TMPDIR" || true; }
trap _cleanup EXIT

# --- Output helpers ---
info()  { echo -e "  \033[1;34m→\033[0m $*"; }
ok()    { echo -e "  \033[1;32m✓\033[0m $*"; }
warn()  { echo -e "  \033[1;33m!\033[0m $*"; }
err()   { echo -e "  \033[1;31m✗\033[0m $*" >&2; }
step()  { echo -e "\n\033[1m[$1/$TOTAL_STEPS]\033[0m $2"; }

# --- Process helpers ---
# PRoot reports full paths as process names, so pgrep -x fails.
# Use plain pgrep/pkill (substring match) instead.
daemon_pid() { pgrep tailscaled 2>/dev/null | head -1; }
daemon_running() { pgrep tailscaled &>/dev/null; }

# --- Preflight checks ---
check_requirements() {
    if ! command -v curl &>/dev/null; then
        err "curl is required but not installed."
        err "Install it with: apt install -y curl"
        exit 1
    fi
}

# --- Self-update ---
get_remote_script_version() {
    curl -fsSL "$SCRIPT_URL" 2>/dev/null | grep -m1 '^SCRIPT_VERSION=' | sed 's/SCRIPT_VERSION="//;s/"//'
}

self_update() {
    local remote_version
    remote_version=$(get_remote_script_version 2>/dev/null) || {
        warn "Could not check for script updates"
        return 0
    }

    if [ -z "$remote_version" ]; then
        warn "Could not determine remote script version"
        return 0
    fi

    if [ "$SCRIPT_VERSION" = "$remote_version" ]; then
        ok "tailscaled-proot script is up to date ($SCRIPT_VERSION)"
        return 0
    fi

    info "Updating tailscaled-proot script: $SCRIPT_VERSION → $remote_version"
    local tmp_script
    tmp_script=$(mktemp)
    if curl -fsSL -o "$tmp_script" "$SCRIPT_URL" 2>/dev/null; then
        local script_path
        script_path=$(realpath "$0" 2>/dev/null || echo "$SCRIPT_DIR/tailscaled-proot")
        cp "$tmp_script" "$script_path"
        chmod +x "$script_path"
        rm -f "$tmp_script"
        ok "Script updated to $remote_version"
        return 0
    else
        rm -f "$tmp_script"
        warn "Failed to download script update"
        return 0
    fi
}

# --- GitHub API helpers ---
fetch_release() {
    local tag="${1:-}"
    local url
    if [ -n "$tag" ]; then
        [[ "$tag" == v* ]] || tag="v$tag"
        url="https://api.github.com/repos/$GITHUB_REPO/releases/tags/$tag"
    else
        url="https://api.github.com/repos/$GITHUB_REPO/releases/latest"
    fi

    local response http_code
    response=$(curl -fsSL -w "\n%{http_code}" "$url" 2>/dev/null) || {
        err "Failed to fetch release from GitHub."
        err "URL: $url"
        err "Check your internet connection or try again later."
        exit 1
    }
    http_code=$(echo "$response" | tail -1)
    response=$(echo "$response" | sed '$d')

    if [ "$http_code" = "403" ]; then
        err "GitHub API rate limit exceeded. Try again in a few minutes."
        exit 1
    elif [ "$http_code" = "404" ]; then
        err "Release '${tag:-latest}' not found."
        err "Check available releases at: https://github.com/$GITHUB_REPO/releases"
        exit 1
    elif [ "$http_code" != "200" ]; then
        err "GitHub API returned HTTP $http_code."
        exit 1
    fi

    echo "$response"
}

get_latest_release() { fetch_release ""; }

get_latest_tag() {
    local release_json="$1"
    echo "$release_json" | grep -m1 '"tag_name"' | sed 's/.*"tag_name": *"//;s/".*//'
}

get_download_url() {
    local release_json="$1"
    local filename="$2"
    echo "$release_json" | grep '"browser_download_url"' | grep "/${filename}\"" | head -1 | sed 's/.*"browser_download_url": *"//;s/".*//'
}

# --- Version helpers ---
installed_cli_version() {
    if [ -x "$CLI_DIR/tailscale" ]; then
        "$CLI_DIR/tailscale" version 2>/dev/null | head -1
    else
        echo "not installed"
    fi
}

installed_daemon_version() {
    if [ -x "$DAEMON_DIR/tailscaled" ]; then
        "$DAEMON_DIR/tailscaled" --version 2>/dev/null | head -1
    else
        echo "not installed"
    fi
}

# --- Daemon management ---
stop_daemon() {
    if ! daemon_running; then
        return 0
    fi
    info "Stopping tailscaled..."
    pkill tailscaled 2>/dev/null || true
    local tries=0
    while [ $tries -lt 10 ] && daemon_running; do
        sleep 0.5
        tries=$((tries + 1))
    done
    if daemon_running; then
        warn "Daemon still running, sending SIGKILL..."
        pkill -9 tailscaled 2>/dev/null || true
        sleep 1
    fi
    ok "Stopped"
}

ensure_daemon_running() {
    if daemon_running && [ -S "$SOCKET" ]; then
        ok "Daemon already running (PID $(daemon_pid))"
        return 0
    fi

    if daemon_running && [ ! -S "$SOCKET" ]; then
        warn "Daemon running but socket missing -- restarting"
        stop_daemon
    fi

    info "Starting tailscaled..."
    rm -f "$SOCKET"
    mkdir -p "$SOCKET_DIR" "$STATE_DIR"
    "$DAEMON_DIR/tailscaled" \
        --state="$STATE_DIR/tailscaled.state" \
        --socket="$SOCKET" \
        --tun=userspace-networking \
        --port=41641 &>/dev/null &
    disown $!

    local tries=0
    while [ $tries -lt 5 ]; do
        [ -S "$SOCKET" ] && break
        sleep 1
        tries=$((tries + 1))
    done

    if [ -S "$SOCKET" ]; then
        ok "Started (PID $(daemon_pid))"
    else
        warn "Daemon may still be starting up (socket not ready yet)"
    fi
}

# --- Auto-start management ---
remove_legacy_autostart() {
    if [ -f "$BASHRC" ] && grep -qF "$LEGACY_BASHRC_MARKER" "$BASHRC"; then
        info "Removing legacy auto-start from ~/.bashrc..."
        local tmp_bashrc
        tmp_bashrc=$(mktemp)
        awk -v marker="$LEGACY_BASHRC_MARKER" '
            $0 ~ marker { skip=1; next }
            skip && /^fi$/ { skip=0; next }
            !skip { print }
        ' "$BASHRC" > "$tmp_bashrc"
        mv "$tmp_bashrc" "$BASHRC"
        ok "Legacy auto-start removed"
    fi
}

install_autostart() {
    remove_legacy_autostart

    if [ -f "$BASHRC" ] && grep -qF "$BASHRC_MARKER" "$BASHRC"; then
        ok "Auto-start already configured in ~/.bashrc"
        return
    fi

    info "Adding auto-start to ~/.bashrc..."
    if [ -f "$BASHRC" ] && [ -s "$BASHRC" ] && [ -n "$(tail -c1 "$BASHRC")" ]; then
        echo "" >> "$BASHRC"
    fi
    cat >> "$BASHRC" << 'SNIPPET'
# --- tailscaled-proot auto-start ---
if command -v tailscaled &>/dev/null && ! pgrep tailscaled &>/dev/null; then
    mkdir -p /var/run/tailscale /var/lib/tailscale
    rm -f /var/run/tailscale/tailscaled.sock
    tailscaled \
        --state=/var/lib/tailscale/tailscaled.state \
        --socket=/var/run/tailscale/tailscaled.sock \
        --tun=userspace-networking \
        --port=41641 &>/dev/null &
    disown $!
    for _ in 1 2 3 4 5; do
        [ -S /var/run/tailscale/tailscaled.sock ] && break
        sleep 1
    done
fi
# --- end tailscaled-proot ---
SNIPPET
    ok "Auto-start configured"
}

remove_autostart() {
    if [ -f "$BASHRC" ] && grep -qF "$BASHRC_MARKER" "$BASHRC"; then
        info "Removing auto-start from ~/.bashrc..."
        local tmp_bashrc
        tmp_bashrc=$(mktemp)
        sed "/$BASHRC_MARKER/,/$BASHRC_END_MARKER/d" "$BASHRC" > "$tmp_bashrc"
        if [ -s "$tmp_bashrc" ]; then
            local content
            content=$(cat "$tmp_bashrc")
            printf '%s\n' "$content" > "$tmp_bashrc"
        fi
        mv "$tmp_bashrc" "$BASHRC"
        ok "Auto-start removed"
    else
        ok "No auto-start found in ~/.bashrc"
    fi
    remove_legacy_autostart
}

# --- Detect architecture ---
detect_arch() {
    local arch
    arch=$(uname -m)
    case "$arch" in
        aarch64|arm64) echo "arm64" ;;
        x86_64|amd64)
            err "x86_64/amd64 is not supported for the patched tailscaled daemon."
            err "GOOS=android/amd64 requires cgo which prevents static builds."
            err "If you're on a regular Linux x86_64 system, use the official tailscale package instead."
            exit 1
            ;;
        armv7l|armhf)
            err "32-bit ARM (armv7l) is not supported for the patched tailscaled daemon."
            err "GOOS=android/arm requires cgo which prevents static builds."
            err "Only arm64 (aarch64) is supported. See the README for building from source."
            exit 1
            ;;
        *)
            err "Unsupported architecture: $arch"
            exit 1
            ;;
    esac
}

# --- Download a file with progress ---
download() {
    local url="$1"
    local dest="$2"
    if ! curl -fSL --progress-bar -o "$dest" "$url"; then
        err "Download failed: $url"
        exit 1
    fi
}

# --- Binary verification ---
verify_checksums() {
    local dir="$1"
    local release_json="$2"

    local checksums_url
    checksums_url=$(get_download_url "$release_json" "SHA256SUMS")

    if [ -z "$checksums_url" ]; then
        warn "No SHA256SUMS found in release -- skipping verification"
        return 0
    fi

    info "Downloading checksums..."
    if ! curl -fsSL -o "$dir/SHA256SUMS" "$checksums_url" 2>/dev/null; then
        warn "Could not download SHA256SUMS -- skipping verification"
        return 0
    fi

    info "Verifying binary integrity..."
    local failed=0
    for bin in tailscale tailscaled; do
        [ -f "$dir/$bin" ] || continue
        local expected actual
        expected=$(grep " ${bin}-arm64$" "$dir/SHA256SUMS" | awk '{print $1}')
        if [ -z "$expected" ]; then
            warn "No checksum found for ${bin}-arm64 -- skipping"
            continue
        fi
        actual=$(sha256sum "$dir/$bin" | awk '{print $1}')
        if [ "$expected" = "$actual" ]; then
            ok "$bin: checksum verified"
        else
            err "$bin: CHECKSUM MISMATCH"
            err "  expected: $expected"
            err "  got:      $actual"
            failed=1
        fi
    done

    rm -f "$dir/SHA256SUMS"

    if [ "$failed" -eq 1 ]; then
        err "Binary verification failed! Downloads may be corrupted or tampered with."
        err "Aborting installation for your safety."
        exit 1
    fi
}

# --- Commands ---

cmd_install() {
    local target_version="${1:-}"
    check_requirements

    echo ""
    echo "  tailscaled-proot installer"
    echo "  =========================="

    TOTAL_STEPS=7
    local arch
    arch=$(detect_arch)

    step 1 "Detecting environment"
    info "Architecture: $arch"
    info "CLI path:     $CLI_DIR/tailscale"
    info "Daemon path:  $DAEMON_DIR/tailscaled"

    step 2 "Fetching release"
    local release_json latest_tag
    release_json=$(fetch_release "$target_version")
    latest_tag=$(get_latest_tag "$release_json")
    local latest_ver="${latest_tag#v}"
    if [ -n "$target_version" ]; then
        ok "Requested release: $latest_tag"
    else
        ok "Latest release: $latest_tag"
    fi

    local current_ver
    current_ver=$(installed_daemon_version)
    if [ "$current_ver" = "$latest_ver" ]; then
        ok "Already installed: $current_ver"

        step 3 "Ensuring configuration"
        if dpkg -l tailscale 2>/dev/null | grep -q '^ii'; then
            info "Removing conflicting apt package 'tailscale'..."
            apt-get remove -y tailscale &>/dev/null || true
            ok "Apt package removed"
        fi
        install_autostart
        ensure_daemon_running

        echo ""
        echo "  =========================="
        ok "Already installed and running ($current_ver)"
        echo ""
        return
    fi

    if [ "$current_ver" != "not installed" ]; then
        info "Existing installation: $current_ver → $latest_ver"
    fi

    local tailscale_url tailscaled_url
    tailscale_url=$(get_download_url "$release_json" "tailscale-${arch}")
    tailscaled_url=$(get_download_url "$release_json" "tailscaled-${arch}")

    if [ -z "$tailscale_url" ] || [ -z "$tailscaled_url" ]; then
        err "Could not find binaries for architecture '$arch' in release $latest_tag"
        exit 1
    fi

    step 3 "Downloading binaries"
    _TMPDIR=$(mktemp -d)

    info "Downloading tailscale (CLI)..."
    download "$tailscale_url" "$_TMPDIR/tailscale"

    info "Downloading tailscaled (daemon)..."
    download "$tailscaled_url" "$_TMPDIR/tailscaled"

    step 4 "Verifying downloads"
    verify_checksums "$_TMPDIR" "$release_json"

    step 5 "Installing"
    stop_daemon
    mkdir -p "$CLI_DIR" "$DAEMON_DIR"
    cp "$_TMPDIR/tailscale" "$CLI_DIR/tailscale"
    cp "$_TMPDIR/tailscaled" "$DAEMON_DIR/tailscaled"
    chmod +x "$CLI_DIR/tailscale" "$DAEMON_DIR/tailscaled"
    ok "Installed $CLI_DIR/tailscale"
    ok "Installed $DAEMON_DIR/tailscaled"

    if dpkg -l tailscale 2>/dev/null | grep -q '^ii'; then
        info "Removing conflicting apt package 'tailscale'..."
        apt-get remove -y tailscale &>/dev/null || true
        ok "Apt package removed"
    fi

    step 6 "Configuring auto-start"
    install_autostart

    step 7 "Starting daemon"
    ensure_daemon_running

    echo ""
    echo "  =========================="
    ok "Installation complete! ($(installed_daemon_version))"
    echo ""
    info "Next steps -- connect to your network (only needed once):"
    echo ""
    echo "    tailscale up \\"
    echo "      --login-server https://YOUR_SERVER:443 \\"
    echo "      --ssh \\"
    echo "      --hostname YOUR_HOSTNAME \\"
    echo "      --authkey YOUR_AUTHKEY"
    echo ""
    info "Or, if using official Tailscale (not Headscale):"
    echo ""
    echo "    tailscale up --ssh --hostname YOUR_HOSTNAME"
    echo ""
    info "The daemon auto-starts every time you open a PRoot-Distro shell."
    echo ""
}

cmd_update() {
    local target_version="${1:-}"
    check_requirements

    echo ""
    echo "  tailscaled-proot updater"
    echo "  ========================"

    TOTAL_STEPS=7

    if [ ! -x "$DAEMON_DIR/tailscaled" ]; then
        err "tailscaled-proot is not installed. Run: tailscaled-proot install"
        exit 1
    fi

    step 1 "Checking for script updates"
    self_update

    local arch
    arch=$(detect_arch)
    local current
    current=$(installed_daemon_version)

    step 2 "Checking binary versions"
    info "Installed: $current"

    step 3 "Fetching release"
    local release_json latest_tag
    release_json=$(fetch_release "$target_version")
    latest_tag=$(get_latest_tag "$release_json")
    local latest_ver="${latest_tag#v}"

    if [ -n "$target_version" ]; then
        ok "Requested: $latest_tag"
    else
        ok "Latest: $latest_tag"
    fi

    if [ -z "$target_version" ] && [ "$current" = "$latest_ver" ]; then
        echo ""
        ok "Already up to date! ($current)"
        echo ""
        return
    fi

    if [ "$current" = "$latest_ver" ]; then
        info "Reinstalling $latest_ver"
    else
        info "Update: $current → $latest_ver"
    fi

    local tailscale_url tailscaled_url
    tailscale_url=$(get_download_url "$release_json" "tailscale-${arch}")
    tailscaled_url=$(get_download_url "$release_json" "tailscaled-${arch}")

    if [ -z "$tailscale_url" ] || [ -z "$tailscaled_url" ]; then
        err "Could not find binaries for architecture '$arch' in release $latest_tag"
        exit 1
    fi

    step 4 "Downloading binaries"
    _TMPDIR=$(mktemp -d)

    info "Downloading tailscale (CLI)..."
    download "$tailscale_url" "$_TMPDIR/tailscale"

    info "Downloading tailscaled (daemon)..."
    download "$tailscaled_url" "$_TMPDIR/tailscaled"

    step 5 "Verifying downloads"
    verify_checksums "$_TMPDIR" "$release_json"

    step 6 "Installing"
    stop_daemon
    cp "$_TMPDIR/tailscale" "$CLI_DIR/tailscale"
    cp "$_TMPDIR/tailscaled" "$DAEMON_DIR/tailscaled"
    chmod +x "$CLI_DIR/tailscale" "$DAEMON_DIR/tailscaled"
    ok "Binaries updated"

    step 7 "Restarting daemon"
    ensure_daemon_running

    echo ""
    echo "  ========================"
    ok "Updated to $(installed_daemon_version)"
    echo ""
}

cmd_status() {
    echo ""
    echo "  tailscaled-proot status"
    echo "  ======================="
    echo ""

    local cli_ver daemon_ver
    cli_ver=$(installed_cli_version)
    daemon_ver=$(installed_daemon_version)

    if [ "$cli_ver" != "not installed" ]; then
        ok "tailscale  (CLI):    $cli_ver  ($CLI_DIR/tailscale)"
    else
        err "tailscale  (CLI):    not installed"
    fi

    if [ "$daemon_ver" != "not installed" ]; then
        ok "tailscaled (daemon): $daemon_ver  ($DAEMON_DIR/tailscaled)"
    else
        err "tailscaled (daemon): not installed"
    fi

    if [ "$cli_ver" != "not installed" ] && [ "$daemon_ver" != "not installed" ] && [ "$cli_ver" != "$daemon_ver" ]; then
        warn "Version mismatch between CLI and daemon"
    fi

    echo ""
    if daemon_running; then
        ok "Daemon: running (PID $(daemon_pid))"
    else
        warn "Daemon: not running"
    fi

    if [ -S "$SOCKET" ]; then
        ok "Socket: $SOCKET"
    else
        warn "Socket: not found"
    fi

    if [ -f "$BASHRC" ] && grep -qF "$BASHRC_MARKER" "$BASHRC"; then
        ok "Auto-start: configured"
    else
        warn "Auto-start: not configured (run: tailscaled-proot install)"
    fi

    if daemon_running && [ -S "$SOCKET" ] && [ -x "$CLI_DIR/tailscale" ]; then
        echo ""
        info "Network status:"
        "$CLI_DIR/tailscale" status 2>&1 | sed 's/^/    /' || true
    fi

    if command -v curl &>/dev/null; then
        echo ""
        info "Checking for updates..."

        local remote_script_ver
        remote_script_ver=$(get_remote_script_version 2>/dev/null) || true
        if [ -n "$remote_script_ver" ] && [ "$SCRIPT_VERSION" != "$remote_script_ver" ]; then
            warn "Script update: $SCRIPT_VERSION → $remote_script_ver"
        else
            ok "Script up to date ($SCRIPT_VERSION)"
        fi

        if [ "$daemon_ver" != "not installed" ]; then
            local release_json latest_tag
            if release_json=$(get_latest_release 2>/dev/null); then
                latest_tag=$(get_latest_tag "$release_json")
                local latest_ver="${latest_tag#v}"
                if [ "$daemon_ver" = "$latest_ver" ]; then
                    ok "Binaries up to date ($daemon_ver)"
                else
                    warn "Binary update: $daemon_ver → $latest_ver"
                fi
            else
                warn "Could not check for binary updates"
            fi
        fi

        if [ -n "$remote_script_ver" ] && [ "$SCRIPT_VERSION" != "$remote_script_ver" ] || \
           { [ -n "${latest_ver:-}" ] && [ "$daemon_ver" != "${latest_ver:-}" ]; }; then
            echo ""
            info "Run: tailscaled-proot update"
        fi
    fi
    echo ""
}

cmd_uninstall() {
    local purge=false
    [ "${1:-}" = "--purge" ] && purge=true

    echo ""
    echo "  tailscaled-proot uninstaller"
    echo "  ============================"

    if $purge; then
        TOTAL_STEPS=4
    else
        TOTAL_STEPS=2
    fi

    local had_something=false

    step 1 "Stopping daemon"
    if daemon_running; then
        stop_daemon
        had_something=true
    else
        ok "Daemon not running"
    fi

    step 2 "Removing binaries"
    if [ -f "$CLI_DIR/tailscale" ]; then
        rm -f "$CLI_DIR/tailscale"
        ok "Removed $CLI_DIR/tailscale"
        had_something=true
    else
        ok "$CLI_DIR/tailscale not present"
    fi
    if [ -f "$DAEMON_DIR/tailscaled" ]; then
        rm -f "$DAEMON_DIR/tailscaled"
        ok "Removed $DAEMON_DIR/tailscaled"
        had_something=true
    else
        ok "$DAEMON_DIR/tailscaled not present"
    fi

    if $purge; then
        step 3 "Removing auto-start"
        remove_autostart

        step 4 "Removing state"
        if [ -d "$STATE_DIR" ]; then
            rm -rf "$STATE_DIR"
            ok "Removed $STATE_DIR"
        else
            ok "No state directory found"
        fi
    fi

    echo ""
    echo "  ============================"
    if $had_something; then
        ok "Uninstalled"
    else
        ok "Nothing to uninstall (already clean)"
    fi

    if ! $purge; then
        echo ""
        info "Config and state preserved -- reinstall with: tailscaled-proot install"
        info "To remove everything:  tailscaled-proot uninstall --purge"
    fi
    info "To remove this script: rm -f $SCRIPT_DIR/tailscaled-proot"
    echo ""
}

cmd_help() {
    cat << 'EOF'

  tailscaled-proot - Patched Tailscale daemon for PRoot-Distro (Termux)

  Run Tailscale (with SSH server + Taildrop) inside PRoot-Distro on
  Android without root access.

  Usage:
    tailscaled-proot install [version]   Install and set up auto-start (latest or specific version)
    tailscaled-proot update  [version]   Update to latest or specific version
    tailscaled-proot status              Show current versions and daemon status
    tailscaled-proot uninstall           Remove binaries (keeps config + state for easy reinstall)
    tailscaled-proot uninstall --purge   Remove everything (binaries, auto-start, state)
    tailscaled-proot help                Show this help message

  Examples:
    tailscaled-proot install             Install the latest release
    tailscaled-proot install v1.96.2     Install a specific version
    tailscaled-proot update              Update to the latest release
    tailscaled-proot update v1.94.0      Downgrade/pin to a specific version
    tailscaled-proot uninstall           Remove binaries, reinstall reconnects automatically
    tailscaled-proot uninstall --purge   Full removal including Tailscale identity

EOF
    echo "  Repository: https://github.com/$GITHUB_REPO"
    echo "  Version:    $SCRIPT_VERSION"
    echo ""
    echo "  This project is not affiliated with or endorsed by Tailscale Inc."
    echo ""
}

# --- Main ---
case "${1:-help}" in
    install)   cmd_install "${2:-}" ;;
    update)    cmd_update "${2:-}" ;;
    status)    cmd_status ;;
    uninstall) cmd_uninstall "${2:-}" ;;
    help|--help|-h) cmd_help ;;
    --version|-v)
        echo "tailscaled-proot $SCRIPT_VERSION"
        ;;
    *)
